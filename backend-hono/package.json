{
  "name": "pb-tracker-backend-hono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "tsx watch src/index.node.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "vercel-build": "npm run db:migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:test": "tsx scripts/migrate-guarded.ts destructive-test",
    "db:migrate:staging": "tsx scripts/migrate-guarded.ts seeded-staging",
    "db:push": "drizzle-kit push",
    "db:seed:staging": "tsx scripts/seed-staging-data.ts",
    "db:smoke:staging": "tsx scripts/check-staging-data.ts",
    "api:smoke:staging": "tsx scripts/check-staging-api.ts",
    "cleanup:untracked-bosses": "tsx scripts/cleanup-untracked-bosses.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@neondatabase/serverless": "^0.10.0",
    "@vercel/functions": "^3.7.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
